{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(America/Los_Angeles)",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["renovate", "dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "automerge": false,
  "platformAutomerge": false,
  "separateMajorMinor": true,
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "enabledManagers": [
    "flux",
    "helm-values",
    "helmv3",
    "kubernetes",
    "custom.regex",
    "github-actions",
    "dockerfile"
  ],
  "flux": {
    "managerFilePatterns": [
      "/(^|/)apps/.+\\.ya?ml$/",
      "/(^|/)infrastructure/.+\\.ya?ml$/",
      "/(^|/)clusters/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)apps/.+\\.ya?ml$/",
      "/(^|/)infrastructure/.+\\.ya?ml$/",
      "/(^|/)charts/.+/values\\.ya?ml$/"
    ]
  },
  "helmv3": {
    "managerFilePatterns": [
      "/(^|/)charts/.+/Chart\\.ya?ml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)apps/.+\\.ya?ml$/",
      "/(^|/)infrastructure/.+\\.ya?ml$/",
      "/(^|/)clusters/.+\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Fallback Docker image repository/tag pairs in YAML",
      "managerFilePatterns": [
        "/(^|/)apps/.+\\.ya?ml$/",
        "/(^|/)infrastructure/.+\\.ya?ml$/",
        "/(^|/)clusters/.+\\.ya?ml$/",
        "/(^|/)charts/.+/(values|templates/.+)\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?m)^\\s*repository:\\s*[\\\"']?(?<depName>[^\\\"'\\s#]+)[\\\"']?\\s*(?:#.*)?\\r?\\n\\s*tag:\\s*[\\\"']?(?<currentValue>[^\\\"'\\s#]+)[\\\"']?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Fallback single-line Docker images in YAML",
      "managerFilePatterns": [
        "/(^|/)apps/.+\\.ya?ml$/",
        "/(^|/)infrastructure/.+\\.ya?ml$/",
        "/(^|/)clusters/.+\\.ya?ml$/",
        "/(^|/)charts/.+/(values|templates/.+)\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?m)^\\s*image:\\s*[\\\"']?(?<depName>(?:[\\w.-]+(?::\\d+)?/)?[\\w./-]+):(?<currentValue>[^@\\\"'\\s#]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?[\\\"']?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Keep minor and patch updates visible but do not automerge by default",
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": false
    },
    {
      "description": "Label and separate major updates",
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-update"]
    },
    {
      "description": "Label container image updates",
      "matchDatasources": ["docker"],
      "addLabels": ["container"]
    },
    {
      "description": "Label Helm chart updates",
      "matchDatasources": ["helm"],
      "addLabels": ["helm"]
    },
    {
      "description": "Label Flux-managed updates",
      "matchManagers": ["flux"],
      "addLabels": ["flux"]
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "labels": ["renovate", "github-actions", "dependencies"]
    },
    {
      "description": "Group infrastructure Helm charts",
      "matchDatasources": ["helm"],
      "matchPackageNames": [
        "cert-manager",
        "traefik",
        "metallb",
        "longhorn",
        "sealed-secrets",
        "kyverno",
        "tailscale-operator",
        "trivy-operator",
        "keda",
        "descheduler",
        "node-feature-discovery",
        "intel-device-plugins-operator"
      ],
      "groupName": "infrastructure",
      "labels": ["renovate", "helm", "infrastructure"]
    },
    {
      "description": "Group monitoring stack Helm charts",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["kube-prometheus-stack", "loki", "promtail"],
      "groupName": "monitoring-stack",
      "labels": ["renovate", "helm", "monitoring"]
    },
    {
      "description": "Label prometheus-community charts",
      "matchDatasources": ["helm"],
      "matchPackageNames": ["kube-prometheus-stack", "prometheus-node-exporter", "prometheus-blackbox-exporter"],
      "labels": ["renovate", "helm", "prometheus-community"]
    },
    {
      "description": "Group LinuxServer container images",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/(^|/)linuxserver\\//"],
      "groupName": "linuxserver-images",
      "labels": ["renovate", "container", "linuxserver"]
    },
    {
      "description": "Label media stack images",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "fallenbagel/jellyseerr",
        "sctx/overseerr",
        "/(^|/)linuxserver/(qbittorrent|sonarr|radarr|prowlarr|sabnzbd)$/"
      ],
      "addLabels": ["media-stack"]
    },
    {
      "description": "Group arr stack images",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/(^|/)(sonarr|radarr|prowlarr|bazarr|overseerr|whisparr)$/",
        "/(^|/)(sonarr|radarr|prowlarr|bazarr|overseerr|whisparr)(:|$)/"
      ],
      "groupName": "arr-stack",
      "labels": ["renovate", "container", "arr-stack"]
    },
    {
      "description": "Pin known rolling Docker tags to digests",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/usekaneo/api",
        "ghcr.io/usekaneo/web",
        "qmcgaw/gluetun",
        "ghcr.io/hotio/whisparr"
      ],
      "pinDigests": true
    },
    {
      "description": "Pin any Docker image still using latest to digests",
      "matchDatasources": ["docker"],
      "matchCurrentValue": "latest",
      "pinDigests": true
    },
    {
      "description": "Bookshelf hardcover-prefixed image tags",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/pennydreadful/bookshelf"],
      "extractVersion": "^hardcover-v(?<version>.*)$",
      "versioning": "loose"
    },
    {
      "description": "Plex image tags use loose versioning; reject arch-suffixed tags (amd64 tag is bare, single-arch variants use suffixes like -arm64/-armhf/-amd64) so Renovate cannot silently swap architectures. See docs/renovate-guardrails.md.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["plexinc/pms-docker"],
      "versioning": "loose",
      "allowedVersions": "!/-(armhf|arm64|arm64v8|arm32v7|arm32v6|aarch64|amd64)$/i"
    },
    {
      "description": "linuxserver/calibre-web only publishes real releases in the 0.x stream; the 5.x tags are orphaned 2021 pushes with a broken OCI config (no ENTRYPOINT). Use loose versioning so LinuxServer's `-lsNNN` build suffix isn't treated as a semver prerelease and excluded. See docs/renovate-guardrails.md.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["lscr.io/linuxserver/calibre-web"],
      "versioning": "loose",
      "allowedVersions": "<1.0.0"
    },
    {
      "description": "LinuxServer images: reject arch-prefixed or arch-suffixed tags (e.g. amd64-<ver>, arm64v8-<ver>, <ver>-amd64) so Renovate can't silently swap architectures. Symmetric to the Plex guard above; covers bazarr/prowlarr/radarr/sonarr/sabnzbd/qbittorrent/etc.",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/(^|/)linuxserver\\//"],
      "allowedVersions": "!/(^(amd64|arm64v8|arm32v7|arm32v6|aarch64|arm64|arm|i386|x86_64)-|-(amd64|arm64v8|arm32v7|arm32v6|aarch64|arm64|arm|i386|x86_64)$)/i"
    },
    {
      "description": "LinuxServer images: require Dependency Dashboard approval for major bumps. Their tagging scheme is inconsistent across images and majors have caused breakage before (e.g. calibre-web 0.6.x -> 5.33.x).",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["/(^|/)linuxserver\\//"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Sure Finance publishes prerelease tags",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/we-promise/sure"],
      "ignoreUnstable": false,
      "respectLatest": false
    }
  ],
  "ignoreDeps": [
    "ghcr.io/fluxcd/flux-cli"
  ]
}
